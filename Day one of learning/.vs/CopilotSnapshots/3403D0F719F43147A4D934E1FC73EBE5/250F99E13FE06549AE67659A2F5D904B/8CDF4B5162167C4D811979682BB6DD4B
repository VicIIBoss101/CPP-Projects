#include <iostream> 
#include <string>

using namespace std;

void addGrade(string names[], int grades[], int listLength) {
	for (int i = 1; i <= listLength; i++) {
		cout << "\n" << "enter a name: ";
		cin >> names[i];
		cout << "\n" << "enter grade: ";
		cin >> grades[i];
	}
}
void showGrades(string names[], int grades[], int listLength) {
	for (int i = 0; i < listLength; i++) {
		cout << "\n" << (i + 1) << ". " << names[i] << " " << grades[i];
	}
}
void checkPassOrFaill(string names[], int grades[], int listLength) {
	for (int i = 0; i < listLength; i++) {
		if (grades[i] < 50) {
			cout << "\n" << names[i] << " faill";
		}
		else {
			cout << "\n" << names[i] << " pass";
		}
	}
}

int main() {

	int choice;
	int listLength;
	string* names = new string[listLength];
	int* grades = new int[listLength];

	while (true) {
		cout << "\n------ Student System ------";
		cout << "\n1. enter grades \n2. Show grade list \n3. Check if student pass of fail \n4. exit";
		cout << "\nEnter your choice: ";
		cin >> choice;

		switch (choice) {

		case 1:
			cout << "\nHow many names do you want to enter: ";
			cin >> listLength;
			addGrade(names, grades , listLength);
			break;

		case 2:
			showGrades(names, grades, listLength);
			break;

		case 3:
			checkPassOrFaill(names, grades, listLength);
			break;

		case 4 :
			cout << "\n" << "welcome to the system !!";
			return 0;

		default:
			cout << "\n" << "Wrong choice !!";

		}
	}
	delete[] names;
	delete[] grades;
}
